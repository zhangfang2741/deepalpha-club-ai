# .env.example — deepalpha-club-ai 环境变量模板
# 复制此文件为 .env 并填写实际值：cp .env.example .env

# ===== 应用基础 =====
APP_ENV=development                          # 环境：development | staging | production
PROJECT_NAME="DeepAlpha Club AI"
VERSION=1.0.0
DEBUG=true

# 产业图谱：图谱为空时启动自动注入 NVIDIA 产业链种子数据（true | false）
SEED_SUPPLY_CHAIN_ON_STARTUP=true
# 启动时自动执行 alembic upgrade head（release 阶段迁移不可靠时的兜底，true | false）
RUN_DB_MIGRATIONS_ON_STARTUP=true

# ===== API 配置 =====
API_V1_STR=/api/v1
ALLOWED_ORIGINS="http://localhost:3000,https://deepalpha.club,https://www.deepalpha.club"   # 允许的跨域来源（逗号分隔）
CORS_ORIGINS="http://localhost:3000,https://deepalpha.club,https://www.deepalpha.club"      # 同上，供前端验证用

# ===== 数据库 PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=deepalpha_db
POSTGRES_USER=deepalpha
POSTGRES_PASSWORD=changeme
POSTGRES_SSL=false                           # 云数据库（如 Supabase）需设为 true
POSTGRES_POOL_SIZE=10                        # 连接池大小
POSTGRES_MAX_OVERFLOW=20                     # 超出连接池时最大额外连接数

# ===== Redis / Valkey 缓存 =====
VALKEY_HOST=                                 # 留空则使用内存缓存；Upstash 填 xxx.upstash.io
VALKEY_PORT=6379
VALKEY_DB=0
VALKEY_PASSWORD=                             # Upstash Redis 密码
VALKEY_SSL=false                             # Upstash 必须设为 true
VALKEY_MAX_CONNECTIONS=10
CACHE_TTL_SECONDS=3600                       # 默认缓存过期时间（秒）

# ===== LLM 供应商 =====
LLM_PROVIDER=claude                          # openai | claude | minimax | gemini
DEFAULT_LLM_MODEL=claude-sonnet-4-5          # 默认使用的模型名称（需与供应商匹配）
DEFAULT_LLM_TEMPERATURE=0.2
MAX_TOKENS=4096
MAX_LLM_CALL_RETRIES=3
LLM_TOTAL_TIMEOUT=60

# 图谱抽取模式（FinReflectKG，arXiv:2508.17906）
# single_pass = 旧版供应链抽取；finreflect_single / finreflect_multi（抽取→规范化两遍） / finreflect_reflection = 论文本体（24 实体/29 关系，5 元组入 finkg_triples）
GRAPH_EXTRACTION_MODE=single_pass
GRAPH_REFLECTION_MAX_ITERS=2                 # finreflect_reflection 最大反思步数 n_max

# OpenAI（LLM_PROVIDER=openai 时使用）
OPENAI_API_KEY=

# Anthropic Claude（LLM_PROVIDER=claude 时使用）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=                          # 留空使用官方地址；接 MiniMax 填 https://api.minimaxi.com/anthropic

# MiniMax（LLM_PROVIDER=minimax 时使用）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Google Gemini（LLM_PROVIDER=gemini 时使用）
GOOGLE_API_KEY=

# ===== JWT 认证 =====
JWT_SECRET_KEY=change-me-in-production       # 生产环境必须替换为随机长字符串（32位+）
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Langfuse 可观测性（可选）=====
LANGFUSE_TRACING_ENABLED=false               # 开启后需要填写下方密钥
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== 限流 =====
RATE_LIMIT_DEFAULT="200 per day,50 per hour"
RATE_LIMIT_CHAT="30 per minute"
RATE_LIMIT_CHAT_STREAM="20 per minute"
RATE_LIMIT_MESSAGES="50 per minute"
RATE_LIMIT_LOGIN="20 per minute"
RATE_LIMIT_REGISTER="10 per hour"

# ===== 日志 =====
LOG_LEVEL=DEBUG
LOG_FORMAT=console                           # console（本地开发）| json（生产）
LOG_DIR=logs

# ===== 会话功能 =====
SESSION_NAMING_ENABLED=true                  # 自动为会话生成名称
LONG_TERM_MEMORY_COLLECTION_NAME=longterm_memory
LONG_TERM_MEMORY_MODEL=claude-haiku-4-5      # 用于记忆提取的轻量模型

# ===== 评估（Eval）=====
EVALUATION_LLM=claude-sonnet-4-5
EVALUATION_API_KEY=                          # 默认使用 ANTHROPIC_API_KEY

# ===== 性能分析（DEBUG 模式）=====
PROFILING_DIR=/tmp/fastapi_profiles
PROFILING_THRESHOLD_SECONDS=2.0

# ===== Financial Modeling Prep API =====
# 免费版每日限额 250 次请求（https://financialmodelingprep.com）
FMP_API_KEY=

# ===== Alpha Vantage API =====
# 免费注册：https://www.alphavantage.co/support/#api-key
# 用于电话会议记录抓取（EARNINGS_CALL_TRANSCRIPT），不设置则用 demo key（限速）
ALPHA_VANTAGE_KEY=

# ===== 网络代理 =====
# 在国内环境下抓取 Yahoo Finance (yfinance) 或 CNN 数据可能需要代理
HTTP_PROXY=
HTTPS_PROXY=
# Company-centric supply-chain graph
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_SSL=false
SUPPLY_CHAIN_WORKER_CONCURRENCY=4
SUPPLY_CHAIN_UNIVERSE=sp500
SUPPLY_CHAIN_VERIFY_THRESHOLD=60
SUPPLY_CHAIN_GENERIC_SUPPLIERS=TSMC,Samsung,Intel,Google Cloud,AWS
SUPPLY_CHAIN_SMALLCAP_MARKETCAP=2e9
SUPPLY_CHAIN_SKIP_RECENT_DAYS=7
SUPPLY_CHAIN_DISCOVER_MODEL=
SUPPLY_CHAIN_VERIFY_MODEL=
SUPPLY_CHAIN_BEAT_ENABLED=false
SUPPLY_CHAIN_DISCOVER_CACHE_TTL=604800
SUPPLY_CHAIN_TRANSCRIPT_QUARTERS=4
SUPPLY_CHAIN_NEWS_LOOKBACK_DAYS=730
SUPPLY_CHAIN_QUOTA_WINDOW_SECONDS=18000
SUPPLY_CHAIN_MAX_QUOTA_RETRIES=10
SUPPLY_CHAIN_MAX_PROBE_ATTEMPTS=10
SUPPLY_CHAIN_PROBE_BACKOFF_SECONDS=60
